{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,

    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "server.ts"],
  "exclude": [
    "src/routers/football/**/*",
    "src/routers/cricket/**/*"
  ]
}